#!/usr/bin/env bash
# multi-cc-im — wrapper exec'd by cc settings.json hook commands + user shell.
#
# Resolves repo root from $BASH_SOURCE so users place the checkout anywhere
# and hooks keep working with a single absolute-path hardcode (CLAUDE.md
# 「禁止硬编码外部 CLI 路径」: only this wrapper's path lands in cc settings;
# everything else is computed).
#
# Two execution modes:
#
# 1. **Production (preferred)** — `apps/multi-cc-im/dist/cli.js` exists from
#    `pnpm --filter multi-cc-im build` (tsup bundle). Cold start ~50ms,
#    matters because cc fires hooks ~2× per assistant turn.
#
# 2. **Dev fallback** — bundle missing → exec via tsx (workspace devDep at
#    node_modules/.bin/tsx). Cold start ~300ms but no build step needed.
#    Node 22-24 default 不能 resolve TS-ESM 风格 import './foo.js' →
#    './foo.ts' (实测 v24.10 ERR_MODULE_NOT_FOUND); tsx handles the rewrite.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DIST_CLI="${REPO_ROOT}/apps/multi-cc-im/dist/cli.js"
SRC_CLI="${REPO_ROOT}/apps/multi-cc-im/src/cli.ts"
TSX_BIN="${REPO_ROOT}/node_modules/.bin/tsx"

if [[ -f "${DIST_CLI}" ]]; then
  exec node "${DIST_CLI}" "$@"
fi

if [[ ! -x "${TSX_BIN}" ]]; then
  echo "multi-cc-im: neither dist/cli.js nor tsx is available" >&2
  echo "  Run \`pnpm install\` from ${REPO_ROOT} (dev mode), or" >&2
  echo "  \`pnpm --filter multi-cc-im build\` to build dist/cli.js (production mode)." >&2
  exit 1
fi

exec "${TSX_BIN}" "${SRC_CLI}" "$@"
